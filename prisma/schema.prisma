// Prisma schema — Backend SaaS contable multi-cliente (LemAPP)
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum PriorityLevel {
  low
  medium
  high
}

enum TaskStatus {
  pending
  in_progress
  completed
}

enum InvoiceStatus {
  draft
  sent
  paid
}

// ---------------------------------------------------------------------------
// RBAC — Control de acceso basado en roles
// ---------------------------------------------------------------------------

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("permissions")
}

// Pivote explícito Role <-> Permission (M:N)
model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now()) @map("assigned_at")

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ---------------------------------------------------------------------------
// Identidad y empresas clientes
// ---------------------------------------------------------------------------

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  fullName String  @map("full_name")
  isActive Boolean @default(true) @map("is_active")

  roleId Int  @map("role_id")
  role   Role @relation(fields: [roleId], references: [id])

  // Multi-tenant: empresas que maneja esta secretaria
  companyAssignments CompanyAssignment[]

  // Tareas
  createdTasks  Task[]        @relation("TaskCreator")
  assignedTasks Task[]        @relation("TaskAssignee")
  taskComments  TaskComment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Company {
  id       Int     @id @default(autoincrement())
  name     String
  taxId    String  @unique @map("tax_id") // NIT / identificación fiscal
  email    String?
  phone    String?
  address  String?
  isActive Boolean @default(true) @map("is_active")

  assignments CompanyAssignment[]
  tasks       Task[]
  invoices    Invoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

// Pivote explícito Company <-> User (M:N) — qué secretaria maneja qué empresa
model CompanyAssignment {
  companyId Int     @map("company_id")
  userId    Int     @map("user_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now()) @map("assigned_at")

  @@id([companyId, userId])
  @@map("company_assignments")
}

// ---------------------------------------------------------------------------
// Transaccionales — tareas y comentarios
// ---------------------------------------------------------------------------

model Task {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus    @default(pending)
  priority    PriorityLevel @default(medium)
  dueDate     DateTime?     @map("due_date")

  companyId Int     @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  // Usuario creador
  createdById Int  @map("created_by_id")
  createdBy   User @relation("TaskCreator", fields: [createdById], references: [id])

  // Usuario asignado (opcional)
  assignedToId Int?  @map("assigned_to_id")
  assignedTo   User? @relation("TaskAssignee", fields: [assignedToId], references: [id])

  comments TaskComment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([assignedToId])
  @@map("tasks")
}

model TaskComment {
  id      Int    @id @default(autoincrement())
  content String

  taskId Int  @map("task_id")
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([taskId])
  @@map("task_comments")
}

// ---------------------------------------------------------------------------
// Facturación
// ---------------------------------------------------------------------------

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique @map("invoice_number")
  status        InvoiceStatus @default(draft)

  subtotal Decimal @db.Decimal(12, 2)
  tax      Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  issueDate DateTime  @default(now()) @map("issue_date")
  dueDate   DateTime? @map("due_date")
  paidAt    DateTime? @map("paid_at")

  // Token único para compartir la factura por WhatsApp
  shareToken String @unique @map("share_token")

  companyId Int     @map("company_id")
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("invoices")
}
